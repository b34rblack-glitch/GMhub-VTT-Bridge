{{!--
  templates/agenda-editor.hbs
  ===========================================================================
  GMhub VTT Bridge — AgendaEditorDialog body.

  Rendered by `ui.js#AgendaEditorDialog`. The same dialog handles both
  the Agenda and Pinned editors — the `isAgenda` / `isPinned` booleans
  switch between the two per-row schemas:

    Agenda mode  -> title + duration + notes
    Pinned mode  -> entity_type select + name + entity_id

  Add / Up / Down / Remove controls work in either mode; per-field
  inputs carry `data-idx` + `data-field` attributes that the JS
  handlers use to thread edits back into the in-memory array.
--}}
<div class="gmhub-agenda-editor">
  {{#if items.length}}
    {{!-- Numbered list of rows. CSS grid in gmhub.css gives each row
         a 3-column layout: content | content | controls. --}}
    <ol class="gmhub-agenda-list">
      {{#each items}}
        <li class="gmhub-agenda-row">
          {{!-- `../` reaches up out of the {{#each}} scope to the
               kind flags set on the root data object. --}}
          {{#if ../isAgenda}}
            {{!-- Agenda row: title (text), estimated minutes (number),
                 notes (textarea). _idx + field travel as data-* attrs
                 so the JS input handler can update the right row. --}}
            <input type="text"
              class="gmhub-agenda-title"
              data-idx="{{this._idx}}" data-field="title"
              placeholder="{{localize "GMHUB.Dialog.AgendaEditor.TitlePlaceholder"}}"
              value="{{this.title}}" />
            <input type="number" min="0" max="999"
              class="gmhub-agenda-minutes"
              data-idx="{{this._idx}}" data-field="estimated_duration_min"
              placeholder="min"
              value="{{this.estimated_duration_min}}" />
            <textarea
              class="gmhub-agenda-notes"
              rows="2"
              data-idx="{{this._idx}}" data-field="notes"
              placeholder="{{localize "GMHUB.Dialog.AgendaEditor.NotesPlaceholder"}}">{{this.notes}}</textarea>
            {{!-- GMV-7: per-scene entity-link picker. Existing links render
                 as removable chips; the Add-entity <select> lists pulled
                 entities grouped by kind, minus those already attached.
                 Pickers use data-action (never data-field) so the generic
                 [data-field] input handler doesn't catch them. --}}
            <div class="gmhub-agenda-entities">
              {{#each this.entities}}
                <span class="gmhub-agenda-entity-chip">{{this.name}}<button
                    type="button" data-action="remove-entity"
                    data-idx="{{../_idx}}" data-entity-id="{{this.id}}"
                    aria-label="{{localize "GMHUB.Dialog.AgendaEditor.RemoveEntity"}}"
                    title="{{localize "GMHUB.Dialog.AgendaEditor.RemoveEntity"}}"
                    {{#if ../../pending}}disabled{{/if}}><i class="fas fa-times" aria-hidden="true"></i></button></span>
              {{/each}}
              <select class="gmhub-agenda-entity-add" data-action="add-entity"
                data-idx="{{this._idx}}" {{#if ../pending}}disabled{{/if}}>
                <option value="">{{localize "GMHUB.Dialog.AgendaEditor.EntityPlaceholder"}}</option>
                {{#if this.availableGroups.length}}
                  {{#each this.availableGroups}}
                    <optgroup label="{{this.label}}">
                      {{#each this.entities}}
                        <option value="{{this.id}}" data-name="{{this.name}}" data-kind="{{../kind}}">{{this.name}}</option>
                      {{/each}}
                    </optgroup>
                  {{/each}}
                {{else}}
                  {{#unless ../anyPulled}}
                    <option value="" disabled>{{localize "GMHUB.Dialog.AgendaEditor.NoEntitiesPulled"}}</option>
                  {{/unless}}
                {{/if}}
              </select>
            </div>
          {{else}}
            {{!-- Pinned row: a single entity picked from the already-pulled
                 entities (grouped by kind), plus an editable display name.
                 The picker OWNS entity_id + entity_type (killing the old
                 free-text id box and the standalone type <select>). A stored
                 id that isn't pulled gets a synthetic selected fallback option
                 (built in getData) so opening the dialog can't blank it.
                 data-action (not data-field) keeps it off the input handler. --}}
            <select class="gmhub-pinned-entity" data-idx="{{this._idx}}"
              data-action="pinned-pick" {{#if ../pending}}disabled{{/if}}>
              <option value="">{{localize "GMHUB.Dialog.AgendaEditor.EntityPlaceholder"}}</option>
              {{#if this.notPulled}}
                <option value="{{this.currentId}}" data-name="{{this.name}}" data-kind="{{this.entity_type}}" selected>{{this.notPulledLabel}}</option>
              {{/if}}
              {{#if this.pickGroups.length}}
                {{#each this.pickGroups}}
                  <optgroup label="{{this.label}}">
                    {{#each this.entities}}
                      <option value="{{this.id}}" data-name="{{this.name}}" data-kind="{{../kind}}" {{#if this.selected}}selected{{/if}}>{{this.name}}</option>
                    {{/each}}
                  </optgroup>
                {{/each}}
              {{else}}
                {{#unless ../anyPulled}}
                  <option value="" disabled>{{localize "GMHUB.Dialog.AgendaEditor.NoEntitiesPulled"}}</option>
                {{/unless}}
              {{/if}}
            </select>
            <input type="text"
              class="gmhub-pinned-name"
              data-idx="{{this._idx}}" data-field="name"
              placeholder="{{localize "GMHUB.Dialog.AgendaEditor.PinnedNamePlaceholder"}}"
              value="{{this.name}}" />
          {{/if}}
          {{!-- Per-row control column. CSS makes this span both rows
               of the grid so the buttons stack vertically. --}}
          <div class="gmhub-agenda-controls">
            <button type="button" data-action="up" data-idx="{{this._idx}}"
              aria-label="{{localize "GMHUB.Dialog.AgendaEditor.MoveUp"}}"
              title="{{localize "GMHUB.Dialog.AgendaEditor.MoveUp"}}" {{#if ../pending}}disabled{{/if}}>
              <i class="fas fa-arrow-up" aria-hidden="true"></i>
            </button>
            <button type="button" data-action="down" data-idx="{{this._idx}}"
              aria-label="{{localize "GMHUB.Dialog.AgendaEditor.MoveDown"}}"
              title="{{localize "GMHUB.Dialog.AgendaEditor.MoveDown"}}" {{#if ../pending}}disabled{{/if}}>
              <i class="fas fa-arrow-down" aria-hidden="true"></i>
            </button>
            <button type="button" data-action="remove" data-idx="{{this._idx}}"
              aria-label="{{localize "GMHUB.Dialog.AgendaEditor.Remove"}}"
              title="{{localize "GMHUB.Dialog.AgendaEditor.Remove"}}" {{#if ../pending}}disabled{{/if}}>
              <i class="fas fa-trash" aria-hidden="true"></i>
            </button>
          </div>
        </li>
      {{/each}}
    </ol>
  {{else}}
    {{!-- No items — empty-state copy. The Add button below still
         renders so the GM can populate from scratch. --}}
    <p class="gmhub-empty-state">{{localize "GMHUB.Dialog.AgendaEditor.Empty"}}</p>
  {{/if}}

  {{!-- Add row — handler injects a kind-appropriate empty record. --}}
  <button type="button" data-action="add" class="gmhub-agenda-add" {{#if pending}}disabled{{/if}}>
    <i class="fas fa-plus"></i> {{localize "GMHUB.Dialog.AgendaEditor.Add"}}
  </button>

  {{!-- Cancel discards in-memory edits; Save persists them, re-renders
       the page HTML, and marks the page dirty for the next Push. --}}
  <footer class="gmhub-dialog-buttons">
    <button type="button" data-action="cancel" {{#if pending}}disabled{{/if}}>
      <i class="fas fa-times"></i> {{localize "GMHUB.Button.Cancel"}}
    </button>
    <button type="button" data-action="save" {{#if pending}}disabled{{/if}}>
      <i class="fas fa-save"></i> {{localize "GMHUB.Dialog.AgendaEditor.Save"}}
    </button>
  </footer>
</div>
